<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    tools:context=".NormalActivity"
    tools:ignore="MissingDefaultResource">

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="6dp"
        android:text="Button text"
        android:textColor="#FF0000"
        android:id="@+id/button"
        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="6dp"
        android:text="Session Replay"
        android:id="@+id/sessionReplayButton"
        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="6dp"
        android:text="Logs"
        android:id="@+id/logsButton"
        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="6dp"
        android:text="Trigger test survey"
        android:id="@+id/triggerSurveyButton"
        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="6dp"
        android:text="Trigger Surveys (Compose)"
        android:id="@+id/openComposeHostButton"
        />

    <EditText
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="6dp"
        android:text="EditText text"
        android:inputType="textVisiblePassword"
        android:textColor="#FF0000"
        android:id="@+id/editText"
        />
</LinearLayout>
